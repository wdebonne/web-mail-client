# Environment Configuration
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=webmail_secure_pwd
DATABASE_URL=postgresql://webmail:webmail_secure_pwd@db:5432/webmail

# Security
SESSION_SECRET=generate-a-random-64-char-string-here
ENCRYPTION_KEY=generate-a-random-32-char-string-here!!

# JWT access token signing key (fallback to SESSION_SECRET if unset).
# Used for short-lived access tokens (15 min) delivered alongside the
# httpOnly refresh cookie. Rotate this to force all access tokens to
# become invalid immediately (refresh cookies remain usable).
# JWT_SECRET=generate-another-random-64-char-string

# WebAuthn / Passkeys (Touch ID, Face ID, Windows Hello)
# RP_ID must be the registrable domain (no protocol, no port, no path).
# ORIGIN must match the full scheme://host[:port] the browser sees.
# In production HTTPS is mandatory except on localhost.
# You can pass multiple origins separated by "," (e.g. when serving both
# the web app and a PWA wrapper).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Web Mail
WEBAUTHN_ORIGIN=http://localhost:5173

# Server
PORT=3000
NODE_ENV=production

# Mail defaults (users configure their own accounts)
# These are fallback values if needed
DEFAULT_IMAP_PORT=993
DEFAULT_SMTP_PORT=465

# ===== Microsoft 365 / Outlook OAuth2 =====
# Required to connect Outlook.com / Hotmail / Live / Microsoft 365 accounts
# (Microsoft disabled Basic Auth for Exchange Online in September 2022, so
# OAuth2 is the ONLY way — including for accounts protected by Microsoft
# Authenticator / MFA).
#
# How to create the credentials (free, even with a personal Microsoft account):
#   1. Go to https://entra.microsoft.com (Microsoft Entra ID, formerly Azure AD)
#      and sign in with your Microsoft account. A free tenant is created
#      automatically — no paid subscription or company required.
#   2. Applications → App registrations → + New registration
#      - Supported account types: "Accounts in any organizational directory
#        and personal Microsoft accounts"
#      - Redirect URI (Web): {PUBLIC_URL}/api/admin/mail-accounts/oauth/microsoft/callback
#   3. Copy "Application (client) ID"          → MICROSOFT_OAUTH_CLIENT_ID
#      Certificates & secrets → New client secret → copy Value
#                                                   → MICROSOFT_OAUTH_CLIENT_SECRET
#   4. API permissions → Add a permission → APIs my organization uses →
#      "Office 365 Exchange Online" → Delegated → IMAP.AccessAsUser.All + SMTP.Send
#      Add a permission → Microsoft Graph → Delegated →
#                                 offline_access, openid, email, profile
#      Grant admin consent (you are admin of your own personal tenant).
#
# These env vars take PRIORITY over any value stored via the Admin UI.
# You can either set them here (recommended for Portainer / Docker) or leave
# them empty and configure through Admin → Comptes mail → section OAuth.
PUBLIC_URL=http://localhost:3000
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# Optional tenant: `common` (default: personal + work/school),
# `organizations` (work/school only), `consumers` (personal only),
# or a specific tenant GUID.
MICROSOFT_OAUTH_TENANT=common
# Optional redirect URI override. Defaults to {PUBLIC_URL}/api/admin/mail-accounts/oauth/microsoft/callback
# MICROSOFT_OAUTH_REDIRECT_URI=

# NextCloud Integration: configured via Admin UI (Admin → NextCloud).
# Credentials are stored encrypted in admin_settings. No env vars needed.

# Client build-time (Vite) variables
# GIPHY API key for the GIF panel in the mail composer.
# Get one for free on https://developers.giphy.com/
# VITE_GIPHY_API_KEY=your_giphy_api_key

# Native Push Notifications (Web Push / VAPID) — optional
# If unset, a key pair is auto-generated on first boot and persisted in
# the admin_settings table. You can generate a pair manually with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@example.com
# NEW_MAIL_POLL_INTERVAL_MS=60000
